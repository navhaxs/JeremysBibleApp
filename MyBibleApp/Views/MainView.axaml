<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:MyBibleApp.Controls"
             xmlns:model="using:MyBibleApp.Models"
             xmlns:vm="using:MyBibleApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="MyBibleApp.Views.MainView"
             x:DataType="vm:MainViewModel">
  <UserControl.Styles>
    <Style Selector="Button.footnote-chip">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="6,0" />
      <Setter Property="MinWidth" Value="24" />
      <Setter Property="Margin" Value="0,0,6,6" />
    </Style>

    <Style Selector="ListBox#ParagraphList">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="IsTabStop" Value="False" />

      <Style.Resources>
        <SolidColorBrush x:Key="ListBoxItemBackgroundPressed" Color="Transparent" />
        <SolidColorBrush x:Key="ListBoxItemBackgroundPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="ListBoxItemBackgroundSelected" Color="Transparent" />
        <SolidColorBrush x:Key="ListBoxItemBackgroundSelectedPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="ListBoxItemBackgroundSelectedPressed" Color="Transparent" />
      </Style.Resources>
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Focusable" Value="False" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:pressed">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:focus">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Fluent renders state visuals on the item template presenter, so clear those too. -->
    <Style Selector="ListBox#ParagraphList > ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
  </UserControl.Styles>

  <Design.DataContext>
    <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
    <vm:MainViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8" Margin="16">
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">
      <TextBlock Grid.Column="0" Text="{Binding Header}" FontSize="20" FontWeight="SemiBold" />
      <ToggleSwitch Grid.Column="1" x:Name="AnnotationToggle" Content="Annotate (Pen)" OffContent="Annotate (Pen)" OnContent="Annotate (Pen)" />
    </Grid>
    <TextBlock Grid.Row="1" Text="{Binding Status}" Opacity="0.8" />
    
    <!-- Main content grid (row 2) with overlay -->
    <Grid Grid.Row="2" RowDefinitions="*">
      <!-- ListBox for Bible content -->
      <ListBox Grid.Row="0" Name="ParagraphList" SelectionMode="Single" SelectionChanged="OnParagraphListSelectionChanged" ItemsSource="{Binding Paragraphs}">
      <ListBox.ItemTemplate>
          <DataTemplate x:DataType="model:BibleParagraph">
            <Grid Margin="0,0,0,14" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
              <TextBlock Grid.Column="0"
                         Grid.RowSpan="2"
                         IsVisible="{Binding HasChapterDropCap}"
                         Text="{Binding ChapterDropCapText}"
                         FontSize="44"
                         FontWeight="Bold"
                         Margin="0,-6,10,0"
                         VerticalAlignment="Top" />
              <controls:LongPressSelectableTextBlock Grid.Column="1"
                                                     Grid.Row="0"
                                                     IsVisible="{Binding IsBodyText}"
                                                     Text="{Binding Text}"
                                                     TextWrapping="Wrap"
                                                     FontSize="19"
                                                     LineHeight="30" />

              <controls:LongPressSelectableTextBlock Grid.Column="1"
                                                     Grid.Row="0"
                                                     IsVisible="{Binding IsHeading}"
                                                     Text="{Binding Text}"
                                                     TextWrapping="Wrap"
                                                     FontSize="19"
                                                     FontWeight="Bold"
                                                     LineHeight="30" />

              <ItemsControl Grid.Column="1" Grid.Row="1" IsVisible="{Binding HasFootnotes}" ItemsSource="{Binding Footnotes}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="model:BibleFootnote">
                    <Button Classes="footnote-chip" Content="{Binding Marker}" Click="OnFootnoteButtonClick" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>
          </DataTemplate>
       </ListBox.ItemTemplate>
      </ListBox>

      <!-- Single full-viewport ink overlay (not hittable – touch falls through to ListBox).
           MainView routes captured pen events here when annotation mode is on. -->
      <controls:InkOverlayCanvas Grid.Row="0" x:Name="InkOverlay" IsHitTestVisible="False" ZIndex="10" />

    </Grid>
  </Grid>
</UserControl>
