<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:MyBibleApp.Controls"
             xmlns:model="using:MyBibleApp.Models"
             xmlns:vm="using:MyBibleApp.ViewModels"
             xmlns:material="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="MyBibleApp.Views.MainView"
             x:DataType="vm:ScriptureViewModel">
  <UserControl.Styles>
    <Style Selector="Button.footnote-chip">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="6,0" />
      <Setter Property="MinWidth" Value="24" />
      <Setter Property="Margin" Value="0,0,6,6" />
    </Style>

    <Style Selector="ListBox#ParagraphList">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="IsTabStop" Value="False" />
      <Setter Property="Padding" Value="0,0,0,80" />

      <Style.Resources>
        <SolidColorBrush x:Key="ListBoxItemBackgroundPressed" Color="Transparent" />
        <SolidColorBrush x:Key="ListBoxItemBackgroundPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="ListBoxItemBackgroundSelected" Color="Transparent" />
        <SolidColorBrush x:Key="ListBoxItemBackgroundSelectedPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="ListBoxItemBackgroundSelectedPressed" Color="Transparent" />
      </Style.Resources>
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Focusable" Value="False" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:pressed">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:focus">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Fluent renders state visuals on the item template presenter, so clear those too. -->
    <Style Selector="ListBox#ParagraphList > ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- ── Navigation bar ────────────────────────────────────────────────── -->

    <!-- Header lookup button: transparent default, subtle fill on hover/press -->
    <Style Selector="Button#HeaderLookupButton">
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10,6" />
      <Style.Resources>
        <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#12808080" />
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#22808080" />
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />
        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
      </Style.Resources>
    </Style>

    <!-- ── Annotation toolbar styles ──────────────────────────────────────── -->

    <!-- Tool buttons: circular icon buttons (pen / eraser) -->
    <Style Selector="ToggleButton.tool-btn">
      <Setter Property="Width" Value="40" />
      <Setter Property="Height" Value="40" />
      <Setter Property="CornerRadius" Value="20" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.tool-btn">
      <Setter Property="Width" Value="40" />
      <Setter Property="Height" Value="40" />
      <Setter Property="CornerRadius" Value="20" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Color swatch buttons: solid-colour circles -->
    <Style Selector="Button.color-swatch">
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="32" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
      <Style.Resources>
        <SolidColorBrush x:Key="ButtonBackground"             Color="Transparent" />
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="Transparent" />
        <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="Transparent" />
      </Style.Resources>
    </Style>

    <!-- Hover: show an outline ring without touching the fill -->
    <Style Selector="Button.color-swatch:pointerover">
      <Setter Property="BorderThickness" Value="2.5" />
      <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
    </Style>

    <!-- Pressed: slightly thicker accent ring -->
    <Style Selector="Button.color-swatch:pressed">
      <Setter Property="BorderThickness" Value="2.5" />
      <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}" />
    </Style>

    <!-- Selected (active) swatch: white ring -->
    <Style Selector="Button.color-swatch.selected">
      <Setter Property="BorderThickness" Value="2.5" />
      <Setter Property="BorderBrush" Value="White" />
    </Style>

    <!-- Floating toolbar: tooltips should not capture pointer events -->
    <Style Selector="#FloatingToolbar Button ToolTip, #FloatingToolbar ToggleButton ToolTip">
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    
    <Style Selector="FlyoutPresenter">
      <Setter Property="Margin"
              Value="0 0 6 6" />
      <Setter Property="CornerRadius"
              Value="6" />
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect
            BlurRadius="6"
            OffsetX="0"
            OffsetY="1"
            Color="#55000000" />
        </Setter.Value>
      </Setter>
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
      <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
    </Style>
    
    <Style Selector="MenuFlyoutPresenter">
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect
            BlurRadius="12"
            OffsetX="3"
            OffsetY="3"
            Color="#66000000" />
        </Setter.Value>
      </Setter>
      <Setter Property="Margin" Value="0 8 12 8" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="BorderBrush" Value="{DynamicResource OutlineBrush}" />
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    </Style>

  </UserControl.Styles>

  <!--<Design.DataContext>
    <vm:ScriptureViewModel />
  </Design.DataContext>-->

  <Panel>
    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="0">
      <Border Grid.Row="0"
              Padding="12,12,12,10"
              BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource ThemeBorderMidBrush}">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">

        <!-- Main app menu button -->
        <Button Grid.Column="0" Classes="tool-btn" VerticalAlignment="Center">
          <material:MaterialIcon Kind="Menu" Width="20" Height="20" />
          <Button.Flyout>
            <Flyout Placement="BottomEdgeAlignedLeft">
              <StackPanel Spacing="12" Margin="4" MinWidth="200">
                <TextBlock Text="Settings" FontWeight="SemiBold" FontSize="15" />
                <Rectangle Height="1" Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.4" />
                <TextBlock Text="Theme" FontSize="13" Opacity="0.7" Margin="0,0,0,4" />
                <StackPanel x:Name="ThemeSwatchPanel"
                            Orientation="Horizontal"
                            Spacing="8" />
                <ToggleSwitch OffContent="Debug mode"
                              OnContent="Debug mode"
                              IsChecked="{Binding AppVM.IsDebugMode, Mode=TwoWay}" />

                <Rectangle Height="1" Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.4" />
                <TextBlock Text="Sync" FontWeight="SemiBold" FontSize="15" />

                <!-- Signed-in account -->
                <Border IsVisible="{Binding AppVM.IsAuthenticated}"
                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        CornerRadius="8"
                        Padding="10,8">
                  <StackPanel Spacing="2">
                    <TextBlock Text="Signed in as"
                               FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBlock Text="{Binding AppVM.CurrentUserEmail}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Syncing…"
                             IsVisible="{Binding AppVM.IsSyncing}"
                             FontSize="12"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource ThemeAccentBrush}" />
                  <TextBlock Text="{Binding AppVM.SyncStatus}"
                             FontSize="12"
                             VerticalAlignment="Center"
                             TextWrapping="Wrap"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Content="Sign in"
                          IsEnabled="{Binding AppVM.CanAuthenticate}"
                          Click="OnSyncAuthButtonClick"
                          Padding="10,6" />
                  <Button Content="Sign out"
                          IsEnabled="{Binding AppVM.IsAuthenticated}"
                          Click="OnSyncSignOutButtonClick"
                          Padding="10,6" />
                  <Button Content="Sync now"
                          IsEnabled="{Binding AppVM.CanForceSync}"
                          Click="OnSyncForceSyncButtonClick"
                          Padding="10,6" />
                </StackPanel>
              </StackPanel>
            </Flyout>
          </Button.Flyout>
        </Button>

        <Button Grid.Column="1"
                x:Name="HeaderLookupButton"
                MinWidth="230"
                HorizontalContentAlignment="Left"
                HorizontalAlignment="Left">
          <TextBlock Text="{Binding Header}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="Left" />
          <Button.Flyout>
            <Flyout Placement="BottomEdgeAlignedLeft">
              <Border Padding="10" MaxWidth="500" MaxHeight="520">
                <StackPanel Spacing="10">
                <Grid ColumnDefinitions="200,90,90" ColumnSpacing="8">
                  <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Text="Books" FontWeight="SemiBold" />
                    <ListBox Name="LookupBooksList"
                             Height="280"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemsSource="{Binding LookupBooks}"
                             SelectedItem="{Binding SelectedLookupBook, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="model:ScriptureLookupBook">
                          <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>

                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Text="Chapters" FontWeight="SemiBold" />
                    <ListBox Name="LookupChaptersList"
                             Height="280"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemsSource="{Binding LookupChapters}"
                             SelectedItem="{Binding SelectedLookupChapter, Mode=TwoWay}" />
                  </StackPanel>

                  <StackPanel Grid.Column="2" Spacing="6">
                    <TextBlock Text="Verses" FontWeight="SemiBold" />
                    <ListBox Name="LookupVersesList"
                             Height="280"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemsSource="{Binding LookupVerses}"
                             SelectedItem="{Binding SelectedLookupVerse, Mode=TwoWay}" />
                  </StackPanel>
                </Grid>
                <Button HorizontalAlignment="Right"
                        Margin="0,10,0,0"
                        MinWidth="96"
                        Content="Go"
                        Click="OnLookupGoButtonClick" />
                </StackPanel>
              </Border>
            </Flyout>
          </Button.Flyout>
        </Button>
        <ToggleButton Grid.Column="2"
                      x:Name="SplitViewToggle"
                      Classes="tool-btn"
                      ToolTip.Tip="Split view"
                      IsCheckedChanged="OnSplitViewToggleIsCheckedChanged">
          <material:MaterialIcon Kind="ViewSplitVertical" Width="20" Height="20" />
        </ToggleButton>
        <ToggleButton Grid.Column="3" x:Name="AnnotationToggle"
                      Classes="tool-btn">
          <material:MaterialIcon Kind="Pen" Width="20" Height="20" />
        </ToggleButton>
        <Button Grid.Column="4"
                x:Name="BibleReadingButton"
                Classes="tool-btn"
                ToolTip.Tip="My Bible Reading"
                Click="OnBibleReadingButtonClick">
          <material:MaterialIcon Kind="BookOpenPageVariant" Width="20" Height="20" />
        </Button>
        </Grid>
      </Border>
      <TextBlock Grid.Row="1"
                 Margin="16,6,16,0"
                 Text="{Binding Status}"
                 IsVisible="{Binding AppVM.IsDebugMode}"
                 Opacity="0.8" />
      
      <!-- Main content grid (row 2) with overlay -->
      <Grid Grid.Row="2" RowDefinitions="*" Margin="0,0,0,0">
        <!-- ListBox for Bible content -->
        <ListBox Grid.Row="0"
                 Name="ParagraphList"
                 SelectionMode="Single"
                 SelectionChanged="OnParagraphListSelectionChanged"
                 ItemsSource="{Binding Paragraphs}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Hidden">
        <ListBox.ItemTemplate>
            <DataTemplate x:DataType="model:BibleParagraph">
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                <!-- Top spacer — only visible before a chapter drop cap -->
                <Border Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Grid.Row="0"
                        IsVisible="{Binding HasChapterDropCap}"
                        Height="32" />
                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                      Margin="24,0,64,14"
                      ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Column="0"
                           Grid.RowSpan="2"
                           IsVisible="{Binding HasChapterDropCap}"
                           Text="{Binding ChapterDropCapText}"
                           FontSize="44"
                           FontWeight="Bold"
                           Margin="0,-6,10,0"
                           VerticalAlignment="Top" />
                <controls:LongPressSelectableTextBlock Grid.Column="1"
                                                     Grid.Row="0"
                                                     IsVisible="{Binding IsBodyText}"
                                                     Text="{Binding Text}"
                                                     TextWrapping="Wrap"
                                                     FontSize="19"
                                                     LineHeight="30" />

                <controls:LongPressSelectableTextBlock Grid.Column="1"
                                                     Grid.Row="0"
                                                     IsVisible="{Binding IsHeading}"
                                                     Text="{Binding Text}"
                                                     TextWrapping="Wrap"
                                                     FontSize="19"
                                                     FontWeight="Bold"
                                                     LineHeight="30" />

                <controls:LongPressSelectableTextBlock Grid.Column="1"
                                                     Grid.Row="0"
                                                     IsVisible="{Binding IsParallelReference}"
                                                     Text="{Binding Text}"
                                                     TextWrapping="Wrap"
                                                     FontSize="15"
                                                     FontStyle="Italic"
                                                     LineHeight="24" />

                <ItemsControl Grid.Column="1"
                              Grid.Row="1"
                              IsVisible="{Binding HasFootnotes}"
                              ItemsSource="{Binding Footnotes}"
                              HorizontalAlignment="Right">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="model:BibleFootnote">
                      <Button Classes="footnote-chip" Content="{Binding Marker}" Click="OnFootnoteButtonClick" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>
              </Grid>
            </DataTemplate>
         </ListBox.ItemTemplate>
        </ListBox>

        <!-- Single full-viewport ink overlay (not hittable – touch falls through to ListBox).
             MainView routes captured pen events here when annotation mode is on. -->
        <controls:InkOverlayCanvas Grid.Row="0" x:Name="InkOverlay" IsHitTestVisible="False" ZIndex="10" />

        <!-- Custom scrollbar — index-based so it stays accurate with virtualization. -->
        <Border x:Name="ReaderProgressTrack"
                Grid.Row="0"
                Width="12"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Background="#15808080"
                ZIndex="20"
                PointerPressed="OnProgressTrackPointerPressed"
                PointerMoved="OnProgressTrackPointerMoved"
                PointerReleased="OnProgressTrackPointerReleased"
                Cursor="Arrow">
          <Canvas>
            <Border x:Name="ReaderProgressThumb"
                    Width="8"
                    Canvas.Left="2"
                    Canvas.Top="0"
                    CornerRadius="4"
                    Background="{DynamicResource ThemeAccentBrush}"
                    Opacity="0.55"
                    Height="40" />
          </Canvas>
        </Border>

        <!-- Chapter markers — shown to the left of the scrollbar while dragging the thumb. -->
        <Canvas x:Name="ChapterMarkersCanvas"
                Grid.Row="0"
                Width="52"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Margin="0,0,14,0"
                IsVisible="False"
                IsHitTestVisible="False"
                ZIndex="19" />

      </Grid>
    </Grid>

    <!-- ── Floating toolbars: chapter nav pill + annotation pill, side by side ── -->
    <StackPanel x:Name="FloatingToolbar"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,20"
                ZIndex="30"
                Spacing="8">

      <!-- Chapter navigation pill (always visible) -->
      <Border CornerRadius="28"
              BorderThickness="1"
              BorderBrush="{DynamicResource ThemeControlHighlightMidBrush}"
              Background="{DynamicResource ThemeBackgroundBrush}"
              Padding="4,4"
              BoxShadow="0 2 8 0 #30000000">
        <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
          <Button x:Name="PrevChapterButton"
                  Classes="tool-btn"
                  IsEnabled="{Binding CanGoToPreviousChapter}"
                  ToolTip.Tip="Previous chapter"
                  Click="OnPrevChapterClick">
            <material:MaterialIcon Kind="ChevronLeft" Width="22" Height="22" />
          </Button>
          <TextBlock Text="{Binding Header}"
                     FontSize="15"
                     FontWeight="SemiBold"
                     Width="160"
                     TextAlignment="Center"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center"
                     Margin="8,0" />
          <Button x:Name="NextChapterButton"
                  Classes="tool-btn"
                  IsEnabled="{Binding CanGoToNextChapter}"
                  ToolTip.Tip="Next chapter"
                  Click="OnNextChapterClick">
            <material:MaterialIcon Kind="ChevronRight" Width="22" Height="22" />
          </Button>
        </StackPanel>
      </Border>

      <!-- Annotation tools pill (visible only while annotation mode is on) -->
      <Border x:Name="AnnotationSection"
              CornerRadius="28"
              BorderThickness="1"
              BorderBrush="{DynamicResource ThemeControlHighlightMidBrush}"
              Background="{DynamicResource ThemeBackgroundBrush}"
              Padding="4,4"
              IsVisible="False"
              BoxShadow="0 2 8 0 #30000000">
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">

          <!-- Pen draw mode -->
          <ToggleButton x:Name="PenModeButton"
                        Classes="tool-btn"
                        IsChecked="True"
                        ToolTip.Tip="Draw"
                        IsCheckedChanged="OnPenModeIsCheckedChanged">
            <material:MaterialIcon Kind="Pencil" Width="20" Height="20" />
          </ToggleButton>

          <!-- Highlighter mode -->
          <ToggleButton x:Name="HighlighterModeButton"
                        Classes="tool-btn"
                        ToolTip.Tip="Highlight"
                        IsCheckedChanged="OnHighlighterModeIsCheckedChanged">
            <material:MaterialIcon Kind="Marker" Width="20" Height="20" />
          </ToggleButton>

          <!-- Eraser mode -->
          <ToggleButton x:Name="EraserModeButton"
                        Classes="tool-btn"
                        ToolTip.Tip="Erase"
                        IsCheckedChanged="OnEraserModeIsCheckedChanged">
            <material:MaterialIcon Kind="Eraser" Width="20" Height="20" />
          </ToggleButton>

          <!-- Undo last stroke -->
          <Button x:Name="UndoButton"
                  Classes="tool-btn"
                  ToolTip.Tip="Undo"
                  Click="OnUndoButtonClick">
            <material:MaterialIcon Kind="Undo" Width="20" Height="20" />
          </Button>

          <!-- Preset colour swatches -->
          <Button x:Name="ColorAmber" Classes="color-swatch" Tag="#D4FFC107" ToolTip.Tip="Amber" Click="OnColorSwatchClick">
            <Ellipse Width="22" Height="22" Fill="#D4FFC107" />
          </Button>
          <Button x:Name="ColorRed"   Classes="color-swatch" Tag="#D4F44336" ToolTip.Tip="Red"   Click="OnColorSwatchClick">
            <Ellipse Width="22" Height="22" Fill="#D4F44336" />
          </Button>
          <Button x:Name="ColorBlue"  Classes="color-swatch" Tag="#D42196F3" ToolTip.Tip="Blue"  Click="OnColorSwatchClick">
            <Ellipse Width="22" Height="22" Fill="#D42196F3" />
          </Button>
          <Button x:Name="ColorDark"  Classes="color-swatch" Tag="#D437474F" ToolTip.Tip="Dark"  Click="OnColorSwatchClick">
            <Ellipse Width="22" Height="22" Fill="#D437474F" />
          </Button>

          <!-- Custom colour picker -->
          <Button x:Name="CustomColorButton"
                  Classes="tool-btn"
                  ToolTip.Tip="Custom colour">
            <material:MaterialIcon Kind="Palette" Width="20" Height="20" />
          </Button>

        </StackPanel>
      </Border>

    </StackPanel>

  </Panel>
</UserControl>
