<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:MyBibleApp.Controls"
             xmlns:model="using:MyBibleApp.Models"
             xmlns:vm="using:MyBibleApp.ViewModels"
             xmlns:material="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="MyBibleApp.Views.MainView"
             x:DataType="vm:MainViewModel">
  <UserControl.Styles>
    <Style Selector="Button.footnote-chip">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="6,0" />
      <Setter Property="MinWidth" Value="24" />
      <Setter Property="Margin" Value="0,0,6,6" />
    </Style>

    <Style Selector="ListBox#ParagraphList">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="IsTabStop" Value="False" />

      <Style.Resources>
        <SolidColorBrush x:Key="ListBoxItemBackgroundPressed" Color="Transparent" />
        <SolidColorBrush x:Key="ListBoxItemBackgroundPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="ListBoxItemBackgroundSelected" Color="Transparent" />
        <SolidColorBrush x:Key="ListBoxItemBackgroundSelectedPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="ListBoxItemBackgroundSelectedPressed" Color="Transparent" />
      </Style.Resources>
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Focusable" Value="False" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:pressed">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:focus">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Fluent renders state visuals on the item template presenter, so clear those too. -->
    <Style Selector="ListBox#ParagraphList > ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox#ParagraphList > ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- ── Annotation toolbar styles ──────────────────────────────────────── -->

    <!-- Tool buttons: circular icon buttons (pen / eraser) -->
    <Style Selector="ToggleButton.tool-btn">
      <Setter Property="Width" Value="40" />
      <Setter Property="Height" Value="40" />
      <Setter Property="CornerRadius" Value="20" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <!-- Color swatch buttons: solid-colour circles -->
    <Style Selector="Button.color-swatch">
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="32" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Selected (active) swatch: white ring -->
    <Style Selector="Button.color-swatch.selected">
      <Setter Property="BorderThickness" Value="2.5" />
      <Setter Property="BorderBrush" Value="White" />
    </Style>
  </UserControl.Styles>

  <Design.DataContext>
    <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
    <vm:MainViewModel />
  </Design.DataContext>

  <Panel>
    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8" Margin="16">
      <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">

        <!-- Main app menu button -->
        <Button Grid.Column="0" FontSize="18" Padding="8,4" VerticalAlignment="Center">
          <Button.Content>☰</Button.Content>
          <Button.Flyout>
            <Flyout Placement="BottomEdgeAlignedLeft">
              <StackPanel Spacing="12" Margin="4" MinWidth="200">
                <TextBlock Text="Settings" FontWeight="SemiBold" FontSize="15" />
                <Rectangle Height="1" Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.4" />
                <ToggleSwitch x:Name="DarkModeToggle"
                              OffContent="Dark mode"
                              OnContent="Dark mode"
                              IsCheckedChanged="OnDarkModeToggleChanged" />
                <ToggleSwitch OffContent="Debug mode"
                              OnContent="Debug mode"
                              IsChecked="{Binding IsDebugMode, Mode=TwoWay}" />
              </StackPanel>
            </Flyout>
          </Button.Flyout>
        </Button>

        <Button Grid.Column="1"
                x:Name="HeaderLookupButton"
                HorizontalAlignment="Left"
                Padding="0"
                Background="Transparent"
                BorderBrush="Transparent">
          <TextBlock Text="{Binding Header}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Button.Flyout>
            <Flyout Placement="BottomEdgeAlignedLeft">
              <Border Padding="10" MaxWidth="500" MaxHeight="520">
                <Grid ColumnDefinitions="200,90,90" ColumnSpacing="8">
                  <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Text="Books" FontWeight="SemiBold" />
                    <ListBox Name="LookupBooksList"
                             Height="280"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemsSource="{Binding LookupBooks}"
                             SelectedItem="{Binding SelectedLookupBook, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="model:ScriptureLookupBook">
                          <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>

                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Text="Chapters" FontWeight="SemiBold" />
                    <ListBox Name="LookupChaptersList"
                             Height="280"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemsSource="{Binding LookupChapters}"
                             SelectedItem="{Binding SelectedLookupChapter, Mode=TwoWay}" />
                  </StackPanel>

                  <StackPanel Grid.Column="2" Spacing="6">
                    <TextBlock Text="Verses" FontWeight="SemiBold" />
                    <ListBox Name="LookupVersesList"
                             Height="280"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemsSource="{Binding LookupVerses}"
                             SelectedItem="{Binding SelectedLookupVerse, Mode=TwoWay}"
                             SelectionChanged="OnLookupVerseSelectionChanged" />
                  </StackPanel>
                </Grid>
              </Border>
            </Flyout>
          </Button.Flyout>
        </Button>
        <ToggleButton Grid.Column="2"
                      x:Name="SplitViewToggle"
                      Classes="tool-btn"
                      ToolTip.Tip="Split view"
                      IsCheckedChanged="OnSplitViewToggleIsCheckedChanged">
          <material:MaterialIcon Kind="ViewSplitVertical" Width="20" Height="20" />
        </ToggleButton>
        <ToggleSwitch Grid.Column="3" x:Name="AnnotationToggle" OffContent="Annotate (Pen)" OnContent="Annotate (Pen)" />
      </Grid>
      <TextBlock Grid.Row="1"
                 Text="{Binding Status}"
                 IsVisible="{Binding IsDebugMode}"
                 Opacity="0.8" />
      
      <!-- Main content grid (row 2) with overlay -->
      <Grid Grid.Row="2" RowDefinitions="*">
        <!-- ListBox for Bible content -->
        <ListBox Grid.Row="0"
                 Name="ParagraphList"
                 SelectionMode="Single"
                 SelectionChanged="OnParagraphListSelectionChanged"
                 ItemsSource="{Binding Paragraphs}"
                 ScrollViewer.VerticalScrollBarVisibility="Hidden">
        <ListBox.ItemTemplate>
            <DataTemplate x:DataType="model:BibleParagraph">
              <Grid Margin="0,0,0,14" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Column="0"
                           Grid.RowSpan="2"
                           IsVisible="{Binding HasChapterDropCap}"
                           Text="{Binding ChapterDropCapText}"
                           FontSize="44"
                           FontWeight="Bold"
                           Margin="0,-6,10,0"
                           VerticalAlignment="Top" />
                <controls:LongPressSelectableTextBlock Grid.Column="1"
                                                     Grid.Row="0"
                                                     IsVisible="{Binding IsBodyText}"
                                                     Text="{Binding Text}"
                                                     TextWrapping="Wrap"
                                                     FontSize="19"
                                                     LineHeight="30" />

                <controls:LongPressSelectableTextBlock Grid.Column="1"
                                                     Grid.Row="0"
                                                     IsVisible="{Binding IsHeading}"
                                                     Text="{Binding Text}"
                                                     TextWrapping="Wrap"
                                                     FontSize="19"
                                                     FontWeight="Bold"
                                                     LineHeight="30" />

                <controls:LongPressSelectableTextBlock Grid.Column="1"
                                                     Grid.Row="0"
                                                     IsVisible="{Binding IsParallelReference}"
                                                     Text="{Binding Text}"
                                                     TextWrapping="Wrap"
                                                     FontSize="15"
                                                     FontStyle="Italic"
                                                     LineHeight="24" />

                <ItemsControl Grid.Column="1"
                              Grid.Row="1"
                              IsVisible="{Binding HasFootnotes}"
                              ItemsSource="{Binding Footnotes}"
                              HorizontalAlignment="Right">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="model:BibleFootnote">
                      <Button Classes="footnote-chip" Content="{Binding Marker}" Click="OnFootnoteButtonClick" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>
            </DataTemplate>
         </ListBox.ItemTemplate>
        </ListBox>

        <!-- Single full-viewport ink overlay (not hittable – touch falls through to ListBox).
             MainView routes captured pen events here when annotation mode is on. -->
        <controls:InkOverlayCanvas Grid.Row="0" x:Name="InkOverlay" IsHitTestVisible="False" ZIndex="10" />

      </Grid>
    </Grid>

    <!-- Reader progress indicator (replaces visible scrollbar). -->
    <!-- Track: full-height strip on the right edge -->
    <Border x:Name="ReaderProgressTrack"
            Width="4"
            HorizontalAlignment="Right"
            VerticalAlignment="Stretch"
            Background="#20808080"
            IsHitTestVisible="False"
            ZIndex="20">
      <!-- Fill: sized from code-behind, top-anchored so it grows downward -->
      <Rectangle x:Name="ReaderProgressFill"
                 Fill="{DynamicResource SystemAccentColor}"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Top"
                 Height="0" />
    </Border>

    <!-- ── Annotation toolbar (visible only while annotation mode is on) ───── -->
    <Border x:Name="AnnotationToolbar"
            IsVisible="False"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,20"
            ZIndex="30"
            CornerRadius="28"
            BorderThickness="1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            Padding="10,6">
      <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">

        <!-- Pen draw mode -->
        <ToggleButton x:Name="PenModeButton"
                      Classes="tool-btn"
                      IsChecked="True"
                      ToolTip.Tip="Draw"
                      IsCheckedChanged="OnPenModeIsCheckedChanged">
          <material:MaterialIcon Kind="Pencil" Width="20" Height="20" />
        </ToggleButton>

        <!-- Eraser mode -->
        <ToggleButton x:Name="EraserModeButton"
                      Classes="tool-btn"
                      ToolTip.Tip="Erase"
                      IsCheckedChanged="OnEraserModeIsCheckedChanged">
          <material:MaterialIcon Kind="Eraser" Width="20" Height="20" />
        </ToggleButton>

        <!-- Undo last stroke -->
        <Button x:Name="UndoButton"
                Classes="tool-btn"
                ToolTip.Tip="Undo"
                Click="OnUndoButtonClick">
          <material:MaterialIcon Kind="Undo" Width="20" Height="20" />
        </Button>

        <!-- Divider -->
        <Rectangle Width="1" Height="28" VerticalAlignment="Center"
                   Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                   Opacity="0.5" Margin="4,0" />

        <!-- Preset colour swatches -->
        <Button x:Name="ColorAmber" Classes="color-swatch" Background="#D4FFC107"
                ToolTip.Tip="Amber" Click="OnColorSwatchClick" />
        <Button x:Name="ColorRed"   Classes="color-swatch" Background="#D4F44336"
                ToolTip.Tip="Red"   Click="OnColorSwatchClick" />
        <Button x:Name="ColorBlue"  Classes="color-swatch" Background="#D42196F3"
                ToolTip.Tip="Blue"  Click="OnColorSwatchClick" />
        <Button x:Name="ColorDark"  Classes="color-swatch" Background="#D437474F"
                ToolTip.Tip="Dark"  Click="OnColorSwatchClick" />

        <!-- Custom colour picker -->
        <Button x:Name="CustomColorButton"
                Classes="tool-btn"
                ToolTip.Tip="Custom colour">
          <material:MaterialIcon Kind="Palette" Width="20" Height="20" />
        </Button>

      </StackPanel>
    </Border>

  </Panel>
</UserControl>
