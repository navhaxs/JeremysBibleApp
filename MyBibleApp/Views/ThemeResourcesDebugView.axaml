<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="using:MyBibleApp.Views"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="MyBibleApp.Views.ThemeResourcesDebugView">
  <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8" Margin="16">

    <TextBlock Grid.Row="0" Text="Debug: Theme Resources" FontSize="18" FontWeight="Bold" />

    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
      <TextBox Grid.Column="0"
               x:Name="SearchBox"
               PlaceholderText="Filter by key name…"
               TextChanged="OnSearchTextChanged" />
      <TextBlock Grid.Column="1"
                 x:Name="CountLabel"
                 VerticalAlignment="Center"
                 Foreground="{DynamicResource ThemeBorderMidBrush}"
                 FontSize="12" />
      <Button Grid.Column="2" Content="Refresh" Click="OnRefreshClick" />
    </Grid>

    <ListBox Grid.Row="2"
             x:Name="ResourceList"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             ScrollViewer.VerticalScrollBarVisibility="Auto">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="views:ThemeResourceEntry">
          <Grid ColumnDefinitions="32,*,Auto" ColumnSpacing="10" Margin="2,4">
            <!-- Color swatch -->
            <Border Grid.Column="0"
                    Width="28" Height="28"
                    CornerRadius="4"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                    Background="{Binding Brush}" />
            <!-- Key name + brush type -->
            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="{Binding Key}"
                         FontFamily="monospace"
                         FontSize="13"
                         TextWrapping="Wrap" />
              <TextBlock Text="{Binding Category}"
                         FontSize="11"
                         Foreground="{DynamicResource ThemeBorderMidBrush}" />
            </StackPanel>
            <!-- Hex value -->
            <TextBlock Grid.Column="2"
                       Text="{Binding Hex}"
                       FontFamily="monospace"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ThemeBorderMidBrush}" />
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <TextBlock Grid.Row="3"
               x:Name="DiagLabel"
               FontFamily="monospace"
               FontSize="11"
               Foreground="{DynamicResource ThemeBorderMidBrush}"
               Margin="0,4,0,0" />

  </Grid>
</UserControl>
