<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="using:MyBibleApp.Views"
             xmlns:vm="using:MyBibleApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="MyBibleApp.Views.AppShellView"
             x:DataType="vm:MainViewModel">
  <UserControl.Styles>
    <Style Selector="Button.passage-tab">
      <Setter Property="Width" Value="78" />
      <Setter Property="MinHeight" Value="46" />
      <Setter Property="Padding" Value="6,4" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="Button.passage-tab.selected">
      <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>

    <!-- Collapse the tab bar on narrow (mobile) widths – toggled from code-behind via SizeChanged -->
    <Style Selector="Border#TabBar">
      <Setter Property="IsVisible" Value="False" />
    </Style>
  </UserControl.Styles>

  <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,*">
    <!-- Debug Controls: tab strip visible only in debug mode -->
    <TabStrip Grid.Row="0"
              Grid.Column="0"
              x:Name="DebugTabStrip"
              IsVisible="{Binding IsDebugMode}"
              Margin="8,4"
              SelectionChanged="OnDebugTabSelectionChanged">
      <TabStripItem Content="Bible Reader" />
      <TabStripItem Content="Debug Pointer" />
      <TabStripItem Content="Debug Drawing" />
      <TabStripItem Content="Sync Debug" />
    </TabStrip>

    <!-- Split-capable content area -->
    <Grid Grid.Row="1" Grid.Column="0" x:Name="ContentGrid">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" MinWidth="120" />
        <ColumnDefinition Width="0" MinWidth="0" />
        <ColumnDefinition Width="0" MinWidth="0" />
      </Grid.ColumnDefinitions>

      <views:MainView Grid.Column="0" x:Name="MainView" />

      <GridSplitter Grid.Column="1"
                    x:Name="PaneSplitter"
                    IsVisible="False"
                    ResizeBehavior="PreviousAndNext"
                    ResizeDirection="Columns"
                    Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    HorizontalAlignment="Stretch" />

      <views:MainView Grid.Column="2" x:Name="SecondaryView" IsVisible="False" />

      <!-- Debug overlays span both panes -->
      <views:DebugPointerView  Grid.Column="0" Grid.ColumnSpan="3" x:Name="DebugView"        IsVisible="False" />
      <views:DebugDrawingView  Grid.Column="0" Grid.ColumnSpan="3" x:Name="DebugDrawingView" IsVisible="False" />
      <views:SyncDebugView     Grid.Column="0" Grid.ColumnSpan="3" x:Name="SyncDebugView"    IsVisible="False" />
    </Grid>

    <!-- Right-edge passage tabs -->
    <Border Grid.Row="0"
            Grid.RowSpan="2"
            Grid.Column="1"
            x:Name="TabBar"
            BorderThickness="1,0,0,0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            Padding="6">
      <Grid RowDefinitions="*,Auto" RowSpacing="8">
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <StackPanel x:Name="TabButtonsHost" Spacing="6" />
        </ScrollViewer>

        <Button Grid.Row="1"
                x:Name="AddTabButton"
                Width="78"
                Height="38"
                FontSize="20"
                Content="+"
                ToolTip.Tip="Add passage tab"
                Click="OnAddTabButtonClick" />
      </Grid>
    </Border>

    <!-- Startup loading overlay (full-shell, shown during initial auth + sync) -->
    <Panel x:Name="StartupOverlay"
           Grid.Row="0" Grid.RowSpan="2"
           Grid.Column="0" Grid.ColumnSpan="2"
           IsVisible="True"
           Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="20"
                  MinWidth="260">
        <TextBlock x:Name="StartupOverlayMessage"
                   Text="Loading…"
                   FontSize="17"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center" />
        <ProgressBar x:Name="StartupOverlayProgress"
                     IsIndeterminate="True"
                     Height="4" />
        <TextBlock x:Name="StartupOverlayDetail"
                   Text="Preparing local data..."
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
      </StackPanel>
    </Panel>
  </Grid>
</UserControl>
