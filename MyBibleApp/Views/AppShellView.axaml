<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="using:MyBibleApp.Views"
             xmlns:vm="using:MyBibleApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="MyBibleApp.Views.AppShellView"
             x:DataType="vm:AppViewModel">
  <UserControl.Styles>
    <Style Selector="Button.passage-tab">
      <Setter Property="Width" Value="38" />
      <Setter Property="MinHeight" Value="120" />
      <Setter Property="Padding" Value="4,6" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="Button.passage-tab.selected">
      <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>

    <!-- Collapse the tab bar on narrow (mobile) widths – toggled from code-behind via SizeChanged -->
    <Style Selector="Border#TabBar">
      <Setter Property="IsVisible" Value="False" />
    </Style>
  </UserControl.Styles>

  <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,*">
    <!-- Debug Controls: tab strip visible only in debug mode -->
    <TabStrip Grid.Row="0"
              Grid.Column="0"
              x:Name="DebugTabStrip"
              IsVisible="{Binding IsDebugMode}"
              Margin="8,4"
              SelectionChanged="OnDebugTabSelectionChanged">
      <TabStripItem Content="Bible Reader" />
      <TabStripItem Content="Debug Pointer" />
      <TabStripItem Content="Debug Drawing" />
      <TabStripItem Content="Sync Debug" />
      <TabStripItem Content="Theme Resources" />
      <TabStripItem Content="Local Storage" />
      <TabStripItem Content="Debug Logs" />
    </TabStrip>

    <!-- Split-capable content area -->
    <Grid Grid.Row="1" Grid.Column="0" x:Name="ContentGrid">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" MinWidth="120" />
        <ColumnDefinition Width="0" MinWidth="0" />
        <ColumnDefinition Width="0" MinWidth="0" />
      </Grid.ColumnDefinitions>

      <views:MainView Grid.Column="0" x:Name="MainView" DataContext="{x:Null}" />

      <GridSplitter Grid.Column="1"
                    x:Name="PaneSplitter"
                    IsVisible="False"
                    ResizeBehavior="PreviousAndNext"
                    ResizeDirection="Columns"
                    Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    HorizontalAlignment="Stretch" />

      <views:MainView Grid.Column="2" x:Name="SecondaryView" IsVisible="False" DataContext="{x:Null}" />

      <!-- Debug overlays span both panes -->
      <views:DebugPointerView  Grid.Column="0" Grid.ColumnSpan="3" x:Name="DebugView"             IsVisible="False" />
      <views:DebugDrawingView  Grid.Column="0" Grid.ColumnSpan="3" x:Name="DebugDrawingView"      IsVisible="False" />
      <views:SyncDebugView     Grid.Column="0" Grid.ColumnSpan="3" x:Name="SyncDebugView"         IsVisible="False" />
      <views:ThemeResourcesDebugView Grid.Column="0" Grid.ColumnSpan="3" x:Name="ThemeResourcesDebugView" IsVisible="False" />
      <views:LocalStorageDebugView   Grid.Column="0" Grid.ColumnSpan="3" x:Name="LocalStorageDebugView"   IsVisible="False" />
      <views:DebugLogsView            Grid.Column="0" Grid.ColumnSpan="3" x:Name="DebugLogsView"          IsVisible="False" />

      <!-- Bible Reading overlay — full-shell, toggled via header button -->
      <views:BibleReadingView  Grid.Column="0" Grid.ColumnSpan="3" x:Name="BibleReadingView" IsVisible="False" ZIndex="25"
                               Background="{DynamicResource ThemeBackgroundBrush}" />

      <!-- Debug log overlay — bottom-left, non-interactive, visible only in debug mode -->
      <Border Grid.Column="0" Grid.ColumnSpan="3"
              IsVisible="{Binding IsDebugMode}"
              IsHitTestVisible="False"
              HorizontalAlignment="Left"
              VerticalAlignment="Bottom"
              MaxWidth="500"
              MaxHeight="180"
              Margin="8,0,0,8"
              Padding="6,4"
              CornerRadius="4"
              ZIndex="50"
              Background="#CC000000">
        <ItemsControl ItemsSource="{Binding DebugLogOverlayLines}"
                      x:Name="DebugLogOverlayItems">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}"
                         FontFamily="Consolas,Courier New,monospace"
                         FontSize="10"
                         Foreground="#CCCCCC"
                         TextTrimming="CharacterEllipsis" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>
    </Grid>

    <!-- Right-edge passage tabs -->
    <Border Grid.Row="0"
            Grid.RowSpan="2"
            Grid.Column="1"
            x:Name="TabBar"
            BorderThickness="1,0,0,0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            Padding="6">
      <Grid RowDefinitions="*,Auto" RowSpacing="8">
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <StackPanel x:Name="TabButtonsHost" Spacing="6" />
        </ScrollViewer>

        <Button Grid.Row="1"
                x:Name="AddTabButton"
                Width="38"
                Height="38"
                FontSize="20"
                Content="+"
                ToolTip.Tip="Add passage tab"
                Click="OnAddTabButtonClick" />
      </Grid>
    </Border>

    <!-- Startup loading overlay (full-shell, shown during initial auth + sync) -->
    <Panel x:Name="StartupOverlay"
           Grid.Row="0" Grid.RowSpan="2"
           Grid.Column="0" Grid.ColumnSpan="2"
           IsVisible="True"
           Background="{DynamicResource ThemeBackgroundBrush}">
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="20"
                  MinWidth="260">
        <TextBlock x:Name="StartupOverlayMessage"
                   Text="Loading…"
                   FontSize="17"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center" />
        <ProgressBar x:Name="StartupOverlayProgress"
                     IsIndeterminate="True"
                     Height="4" />
        <TextBlock x:Name="StartupOverlayDetail"
                   Text="Preparing local data..."
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />

        <!-- Re-sign-in prompt shown when the previous session has expired -->
        <StackPanel x:Name="StartupReSignInPanel"
                    IsVisible="False"
                    Spacing="8">
          <Button x:Name="StartupSignInAgainButton"
                  Content="Sign in again"
                  HorizontalAlignment="Center"
                  Padding="24,8"
                  Click="OnStartupSignInAgainButtonClick" />
          <Button x:Name="StartupContinueWithoutSignInButton"
                  Content="Continue without signing in"
                  HorizontalAlignment="Center"
                  Padding="24,8"
                  Click="OnStartupContinueWithoutSignInButtonClick" />
        </StackPanel>
      </StackPanel>
    </Panel>

    <!-- Sign-in in progress overlay (floats above all content while browser auth is open) -->
    <Panel x:Name="SignInProgressOverlay"
           Grid.Row="0" Grid.RowSpan="2"
           Grid.Column="0" Grid.ColumnSpan="2"
           IsVisible="False"
           Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="20"
                  MinWidth="260">
        <TextBlock Text="Waiting for sign-in…"
                   FontSize="17"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center" />
        <ProgressBar IsIndeterminate="True" Height="4" />
        <TextBlock Text="A sign-in page has been opened in your browser."
                   FontSize="12"
                   HorizontalAlignment="Center"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   MaxWidth="300"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        <Button x:Name="ReopenBrowserButton"
                Content="Open browser again"
                HorizontalAlignment="Center"
                Padding="24,8"
                Click="OnReopenBrowserButtonClick" />
        <Button x:Name="CancelSignInButton"
                Content="Cancel"
                HorizontalAlignment="Center"
                Padding="24,8"
                Click="OnCancelSignInButtonClick" />
      </StackPanel>
    </Panel>
  </Grid>
</UserControl>
