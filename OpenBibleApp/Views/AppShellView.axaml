<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="using:OpenBibleApp.Views"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="OpenBibleApp.Views.AppShellView">
  <Grid RowDefinitions="Auto,*">
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="8">
      <Button Name="DebugToggle" Content="Show Debug Pointer (Dev)" Click="OnDebugToggleClick" Width="200" />
      <Button Name="DebugDrawingToggle" Content="Show Debug Drawing (Dev)" Click="OnDebugDrawingToggleClick" Width="200" />
    </StackPanel>
    <views:MainView Grid.Row="1" x:Name="MainView" />
    <views:DebugPointerView Grid.Row="1" x:Name="DebugView" IsVisible="False" />
    <views:DebugDrawingView Grid.Row="1" x:Name="DebugDrawingView" IsVisible="False" />
  </Grid>
</UserControl>



